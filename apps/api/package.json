{
  "name": "@reloop/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "tsx src/index.ts",
    "eval": "tsx src/eval/run.ts",
    "test:edge": "tsx src/eval/edge-cases.ts",
    "reprice:trace": "tsx src/scripts/reprice-trace.ts",
    "seed:demand": "tsx src/scripts/seedDemandEvents.ts",
    "aggregate:demand": "tsx src/scripts/runDemandAggregation.ts",
    "seed:buyers": "tsx src/scripts/seedBuyers.ts",
    "demo:notify": "tsx src/scripts/demoBuyerNotification.ts",
    "demo:jordan": "tsx src/scripts/demoJordanReturn.ts",
    "demo:blue-dunk": "tsx src/scripts/demoBlueDunkReturn.ts",
    "inspect:demo": "tsx src/scripts/inspectDemoState.ts",
    "reset:returns": "tsx src/scripts/resetReturns.ts",
    "demo:seed-notifications": "tsx src/scripts/seedDemoScenario.ts",
    "export:pricing-transactions": "tsx src/scripts/exportPricingTransactions.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1080.0",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/lib-dynamodb": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@reloop/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "langfuse": "^3.38.20",
    "mongodb": "^6.10.0",
    "node-cron": "^3.0.3",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.6.3"
  }
}
