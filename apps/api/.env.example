# Copy to .env and fill in. .env is gitignored — never commit real keys.

# NVIDIA-hosted inference (OpenAI-compatible chat API).
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Grading model (vision) and pricing model (text).
GRADING_PROVIDER=chat-vlm
GRADING_MODEL=meta/llama-3.2-90b-vision-instruct
PRICING_MODEL=meta/llama-3.3-70b-instruct

# Server
PORT=4000
WEB_ORIGIN=http://localhost:3000

# MongoDB Atlas — backs dummy username/password login. Optional: if unset, auth
# routes return 503 and the web falls back to handle-only login.
# Get a free connection string at https://www.mongodb.com/cloud/atlas (M0 tier).
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=reloop
