# Copy to .env and fill in. .env is gitignored — never commit real keys.

# NVIDIA-hosted inference (OpenAI-compatible chat API).
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Grading model (vision) and pricing model (text).
# GRADING_PROVIDER=trained-local uses our own CLIP-condition grader
# (ai-grading/serve.py), with automatic fallback to chat-vlm (NVIDIA) on
# error/timeout. Dev default is trained-local (run `cd ai-grading && python serve.py`
# first); set this to chat-vlm in Render/prod, since nothing runs Flask there.
GRADING_PROVIDER=trained-local
GRADING_MODEL_URL=http://127.0.0.1:8000
GRADING_MODEL=meta/llama-3.2-90b-vision-instruct
PRICING_MODEL=meta/llama-3.1-70b-instruct

# Calibration shim applied on top of the trained grader's output. The ai-grading
# checkpoint is already calibrated, so leave these at 0/poor/0 — the legacy
# defaults (leniency 1, floor 'fair') bump every grade one step toward "new" and
# clip Salvage, which collapses the model's whole score range onto Grade A.
GRADER_LENIENCY=0
GRADER_FLOOR=poor
GRADER_SOFTEN_ISSUES=0

# Server
PORT=4000
WEB_ORIGIN=http://localhost:3000

# MongoDB Atlas — backs dummy username/password login. Optional: if unset, auth
# routes return 503 and the web falls back to handle-only login.
# Get a free connection string at https://www.mongodb.com/cloud/atlas (M0 tier).
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=reloop

# Langfuse — traces every NVIDIA model call (model, prompt, response, latency).
# Optional: if unset, LLM calls run untraced with zero overhead.
# Get free keys at https://cloud.langfuse.com (or point LANGFUSE_BASE_URL at a
# self-hosted instance).
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Spec 025: shared secret gating /api/grade, /api/route, /api/return/checkpoint,
# /api/health-card once the async S3->SQS->Lambda return pipeline is live (see
# infra/). Optional: if unset, these routes are unauthenticated (fine for local
# dev). Generate with `openssl rand -hex 32`; must match the value
# infra/provision.sh deploys the return-worker Lambda with.
INTERNAL_API_SECRET=
